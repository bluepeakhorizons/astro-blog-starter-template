---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Secure Operations. Strategic Growth.</h1>
				<p>
					Blue Peak Horizons LLC specializes in providing high-quality cybersecurity consulting services, 
					including FedRAMP assessments, RMF compliance, and secure software development guidance[cite: 2]. 
					We bridge the gap between complex federal requirements and corporate operational efficiency.
				</p>
				<p>
					<strong>Our Mission:</strong> To help organizations achieve a robust security posture while 
					simplifying the path to compliance[cite: 3].
				</p>
			</section>

			<hr />

			<section class="services">
				<h2>Our Core Capabilities</h2>
				
				<div class="service-grid">
					<div class="service-category">
						<h3>Cybersecurity & Compliance</h3>
						<ul>
							<li>FedRAMP Initial Assessment & Gap Analysis [cite: 4]</li>
							<li>RMF Compliance & Security Control Documentation [cite: 2, 4]</li>
							<li>Continuous Monitoring & Risk Management [cite: 4]</li>
							<li>Cybersecurity Policy & SOP Development [cite: 4]</li>
							<li>Secure Software Development Guidance [cite: 2]</li>
						</ul>
					</div>

					<div class="service-category">
						<h3>Procurement & Supply Chain</h3>
						<ul>
							<li>Federal & Corporate Procurement Strategy</li>
							<li>Supply Chain Security Consulting & Risk Mitigation [cite: 4]</li>
							<li>Vendor Management & Strategic Sourcing</li>
							<li>Acquisition Support for Government Contractors</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="cta">
				<h2>Partner With Us</h2>
				<p>Ready to secure your federal contracts or optimize your corporate supply chain?</p>
				<a href="mailto:contact@bluepeakhorizons.com" class="button">Schedule a Consultation</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
