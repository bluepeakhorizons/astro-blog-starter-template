---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Blue Peak Horizons LLC</h1>
				<p>
					Specializing in high-quality cybersecurity consulting and strategic procurement[cite: 2]. 
					Our mission is to help organizations achieve a robust security posture while simplifying compliance[cite: 3].
				</p>
			</section>

			<section class="services">
				<h2>Core Capabilities</h2>
				<div class="service-grid">
					<div>
						<h3>Cybersecurity</h3>
						<ul>
							<li>FedRAMP Initial Assessment & Gap Analysis [cite: 5]</li>
							<li>Security Control Implementation & Documentation [cite: 5]</li>
							<li>Continuous Monitoring & Risk Management [cite: 5]</li>
							<li>Secure Software Development Guidance [cite: 2]</li>
						</ul>
					</div>
					<div>
						<h3>Procurement</h3>
						<ul>
							<li>Federal & Corporate Procurement Strategy</li>
							<li>Supply Chain Security Consulting [cite: 5]</li>
							<li>Cybersecurity Policy & SOP Development [cite: 5]</li>
						</ul>
					</div>
				</div>
			</section>

			<hr />

			<section id="contact" class="contact-section">
				<h2>Contact Our Experts</h2>
				<p>Inquire about our FedRAMP assessments, RMF compliance, or procurement services[cite: 2].</p>
				
				<form class="contact-form" action="#" method="POST">
					<div class="form-group">
						<label for="name">Full Name</label>
						<input type="text" id="name" name="name" required placeholder="John Doe" />
					</div>

					<div class="form-group">
						<label for="email">Business Email</label>
						<input type="email" id="email" name="email" required placeholder="name@company.com" />
					</div>

					<div class="form-group">
						<label for="organization">Organization / Agency</label>
						<input type="text" id="organization" name="organization" required placeholder="Company Name" />
					</div>

					<div class="form-group">
						<label for="service">Service of Interest</label>
						<select id="service" name="service">
							<option value="cybersecurity">Cybersecurity Consulting</option>
							<option value="fedramp">FedRAMP / RMF Assessment</option>
							<option value="procurement">Procurement & Supply Chain</option>
							<option value="other">Other Inquiry</option>
						</select>
					</div>

					<div class="form-group">
						<label for="message">Message</label>
						<textarea id="message" name="message" rows="5" required placeholder="How can we help your organization simplify compliance?"></textarea>
					</div>

					<button type="submit" class="submit-button">Submit Inquiry</button>
				</form>
			</section>

			<section class="social-cta">
				<a href="https://www.linkedin.com/company/blue-peak-horizons" target="_blank" rel="noopener noreferrer" class="linkedin-button">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
					</svg>
					Connect on LinkedIn
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: auto;
		padding: 2rem 1rem;
		line-height: 1.6;
	}
	.service-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
		margin-bottom: 2rem;
	}
	@media (max-width: 600px) {
		.service-grid { grid-template-columns: 1fr; }
	}

	/* Form Styles */
	.contact-section {
		background: #f9f9f9;
		padding: 2.5rem;
		border-radius: 8px;
		border: 1px solid #e0e0e0;
		margin: 3rem 0;
	}
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	label {
		font-weight: bold;
		font-size: 0.9rem;
		color: #444;
	}
	input, select, textarea {
		padding: 0.8rem;
		border: 1px solid #ccc;
		border-radius: 4px;
		font-size: 1rem;
	}
	.submit-button {
		background-color: #004a99;
		color: white;
		padding: 1rem;
		border: none;
		border-radius: 4px;
		font-weight: bold;
		cursor: pointer;
		transition: background 0.3s ease;
	}
	.submit-button:hover {
		background-color: #003366;
	}

	.social-cta { text-align: center; margin-top: 2rem; }
	.linkedin-button {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background-color: #0077b5;
		color: white;
		padding: 10px 20px;
		border-radius: 4px;
		text-decoration: none;
		font-weight: bold;
	}
</style>
