---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contactus">Contact Us</HeaderLink>
		</div>
		<div class="social-links">
		
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
		flex: 1; /* Added to take up equal space on the left */
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	
	/* Centering Logic */
	.internal-links {
		display: flex;
		justify-content: center;
		flex: 1; /* Added to allow centering within the nav */
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex; [cite: 10]
		flex: 1; /* Added to take up equal space on the right */
		justify-content: flex-end; /* Keeps social links aligned to the right edge */
	}
	
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		/* Optional: Remove centering on mobile if the logo needs more space */
		h2, .internal-links {
			flex: initial;
		}
	}
</style>
