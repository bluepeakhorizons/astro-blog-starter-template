---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Secure Operations. Strategic Growth.</h1>
				<p>
					Blue Peak Horizons LLC specializes in providing high-quality cybersecurity consulting services, 
					including FedRAMP assessments, RMF compliance, and secure software development guidance. 
					We bridge the gap between complex federal requirements and corporate operational efficiency.
				</p>
				<p>
					<strong>Our Mission:</strong> To help organizations achieve a robust security posture while 
					simplifying the path to compliance.
				</p>
			</section>

			<hr />

			<section class="services">
				<h2>Our Core Capabilities</h2>
				
				<div class="service-grid">
					<div class="service-category">
						<h3>Cybersecurity & Compliance</h3>
						<ul>
							<li>FedRAMP Initial Assessment & Gap Analysis</li>
							<li>RMF Compliance & Security Control Documentation</li>
							<li>Continuous Monitoring & Risk Management</li>
							<li>Cybersecurity Policy & SOP Development</li>
							<li>Secure Software Development Guidance</li>
						</ul>
					</div>

					<div class="service-category">
						<h3>Procurement & Supply Chain</h3>
						<ul>
							<li>Federal & Corporate Procurement Strategy</li>
							<li>Supply Chain Security Consulting & Risk Mitigation</li>
							<li>Vendor Management & Strategic Sourcing</li>
							<li>Acquisition Support for Government Contractors</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="cta">
				<h2>Partner With Us</h2>
				<p>Ready to secure your federal contracts or optimize your corporate supply chain?</p>
				<a href="mailto:contact@bluepeakhorizons.com" class="button">Schedule a Consultation</a>
			</section>
			<section class="social-cta">
				<h2>Connect on Socials</h2>
				<p>Stay updated on cybersecurity compliance and procurement trends.</p>
				<a href="https://www.linkedin.com/company/blue-peak-horizons" target="_blank" rel="noopener noreferrer" class="linkedin-button">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
					</svg>
					Follow Blue Peak Horizons on LinkedIn
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
